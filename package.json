{
  "name": "hono-boilerplate",
  "description": "boilerplate to run a js server using bun or node",
  "version": "1.6.5",
  "author": "Marcos <hello@marcosrjjunior.com>",
  "scripts": {
    "bun:build": "bun build src/bun.ts --compile --minify --target bun --outfile api",
    "bun:dev": "bun run --hot src/bun.ts",
    "bun:start": "./api",
    "dev": "pnpm node:dev",
    "node:dev": "dotenvx run -- tsx watch src/node.ts",
    "node:build": "tsc -p .",
    "node:start": "node ./dist/node.js",
    "test": "bun test ./src/app",
    "test:integration": "bun test --preload ./src/tests/setup.ts ./src/tests",
    "db:migrate:up": "dotenvx run -- tsx ./src/lib/db/migrate latest",
    "db:migrate:down": "dotenvx run -- tsx ./src/lib/db/migrate down",
    "db:migrate:redo": "dotenvx run -- tsx ./src/lib/db/migrate down-to NO_MIGRATIONS && pnpm db:migrate:up && pnpm db:generate:types",
    "db:migrate:create": "dotenvx run -- tsx ./src/lib/db/migrate create initial",
    "db:seed": "dotenvx run -- tsx ./src/lib/db/seed",
    "db:reset": "pnpm db:migrate:redo && pnpm db:seed",
    "db:generate:types": "kysely-codegen --runtime-enums --out-file=./src/lib/db/schema.d.ts && pnpm db:types:prettier",
    "db:types:prettier": "prettier --write ./src/lib/db/schema.d.ts",
    "check-types": "tsc --noemit --skipLibCheck",
    "lint": "eslint ./src --max-warnings 0 && pnpm check-types",
    "lint:fix": "eslint ./src --fix",
    "prettier": "prettier --write ./src"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.71.0",
    "@hono/node-server": "^2.0.4",
    "@hono/zod-openapi": "^1.4.0",
    "@scalar/hono-api-reference": "^0.10.20",
    "hono": "^4.12.23",
    "kysely": "^0.29.2",
    "kysely-migration-cli": "^0.4.2",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.14",
    "@types/pg": "^8.20.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-unused-imports": "^4.4.1",
    "kysely-codegen": "^0.20.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  }
}
